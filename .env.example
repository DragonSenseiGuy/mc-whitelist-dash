# SSH connection to the Minecraft server host
MC_SSH_HOST=                          # Tailscale IP or hostname of the remote host
MC_SSH_USER=server                    # SSH username on the remote host
MC_SSH_KEY_PATH=/etc/mc-dashboard/id_ed25519

# Auth
ADMIN_JWT_SECRET=                     # Generate with: openssl rand -hex 32

# Docker volume mount — absolute path to the SSH private key on the VPS host
SSH_KEY_PATH=/etc/mc-dashboard/id_ed25519

# Domain for Traefik routing
DASHBOARD_DOMAIN=mc-admin.example.com

# Let's Encrypt email for certificate notifications
ACME_EMAIL=you@example.com
